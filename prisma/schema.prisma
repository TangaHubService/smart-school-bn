generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum StudentGender {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum ParentRelationship {
  MOTHER
  FATHER
  GUARDIAN
  OTHER
}

enum AttendanceSessionStatus {
  OPEN
  CLOSED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum LessonContentType {
  TEXT
  PDF
  VIDEO
  LINK
}

enum SubmissionStatus {
  SUBMITTED
  GRADED
}

enum AssessmentType {
  GENERAL
  OPENENDED
  PSYCHOMETRIC
  INTERVIEW
}

enum AssessmentQuestionType {
  MCQ_SINGLE
  OPEN_TEXT
}

enum AssessmentAttemptStatus {
  IN_PROGRESS
  SUBMITTED
}

enum FileAssetResourceType {
  IMAGE
  VIDEO
  RAW
}

enum ResultSnapshotStatus {
  LOCKED
  PUBLISHED
}

enum ExamType {
  CAT
  EXAM
}

enum ConductSeverity {
  LOW
  MODERATE
  HIGH
  CRITICAL
}

enum ConductIncidentStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
}

enum ConductActionType {
  WARNING
  COUNSELING
  PARENT_MEETING
  COMMUNITY_SERVICE
  DETENTION
  SUSPENSION
  OTHER
}

enum ConductFeedbackAuthorType {
  SCHOOL_STAFF
  GOV_AUDITOR
}

enum GovScopeLevel {
  SECTOR
  DISTRICT
  PROVINCE
  COUNTRY
}

model Tenant {
  id                 String   @id @default(uuid())
  code               String   @unique
  name               String
  domain             String?  @unique
  isActive           Boolean  @default(true)
  isAcademyCatalog   Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  school        School?
  users         User[]
  roles         Role[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  invites       Invite[]
  academicYears AcademicYear[]
  terms         Term[]
  gradeLevels   GradeLevel[]
  classRooms    ClassRoom[]
  subjects      Subject[]
  students      Student[]
  enrollments   StudentEnrollment[]
  parents       Parent[]
  parentLinks   ParentStudent[]
  attendanceSessions AttendanceSession[]
  attendanceRecords  AttendanceRecord[]
  courses       Course[]
  lessons       Lesson[]
  assignments   Assignment[]
  submissions   Submission[]
  assessments        Assessment[]
  assessmentQuestions AssessmentQuestion[]
  assessmentOptions   AssessmentOption[]
  assessmentAttempts  AssessmentAttempt[]
  assessmentAnswers   AssessmentAnswer[]
  gradingSchemes GradingScheme[]
  exams         Exam[]
  examMarks     ExamMark[]
  resultSnapshots ResultSnapshot[]
  fileAssets    FileAsset[]
  conductIncidents ConductIncident[]
  conductActions   ConductAction[]
  conductFeedbacks ConductFeedback[]
  conductGrades    ConductGrade[]
  programs             Program[]
  payments             Payment[]
  paymentsAsBuyer      Payment[]            @relation("PaymentBuyerTenant")
  programEnrollments ProgramEnrollment[]
  timetableSlots  TimetableSlot[]
  announcements   Announcement[]
  passwordResetTokens PasswordResetToken[]

  @@index([isActive])
}

model School {
  id                 String    @id @default(uuid())
  tenantId           String    @unique
  displayName        String
  registrationNumber String?   @unique
  email              String?
  phone              String?
  addressLine1       String?
  addressLine2       String?
  province           String?
  city               String?
  district           String?
  sector             String?
  cell               String?
  village            String?
  country            String    @default("Rwanda")
  timezone           String    @default("Africa/Kigali")
  setupCompletedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([country])
  @@index([country, province, district, sector])
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  phone        String?
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  sentInvites     Invite[]       @relation("InviteSentBy")
  acceptedInvites Invite[]       @relation("InviteAcceptedBy")
  parentProfile   Parent?
  studentProfile  Student?
  createdAttendanceSessions AttendanceSession[] @relation("AttendanceSessionCreatedBy")
  editedAttendanceSessions  AttendanceSession[] @relation("AttendanceSessionEditedBy")
  markedAttendanceRecords   AttendanceRecord[]  @relation("AttendanceRecordMarkedBy")
  editedAttendanceRecords   AttendanceRecord[]  @relation("AttendanceRecordEditedBy")
  taughtCourses            Course[]            @relation("CourseTeacher")
  managedExams             Exam[]              @relation("ExamTeacher")
  authoredAnnouncements    Announcement[]      @relation("AnnouncementAuthor")
  createdGradingSchemes    GradingScheme[]     @relation("GradingSchemeCreatedBy")
  updatedGradingSchemes    GradingScheme[]     @relation("GradingSchemeUpdatedBy")
  createdExams             Exam[]              @relation("ExamCreatedBy")
  updatedExams             Exam[]              @relation("ExamUpdatedBy")
  enteredExamMarks         ExamMark[]          @relation("ExamMarkEnteredBy")
  updatedExamMarks         ExamMark[]          @relation("ExamMarkUpdatedBy")
  lockedResultSnapshots    ResultSnapshot[]    @relation("ResultSnapshotLockedBy")
  publishedResultSnapshots ResultSnapshot[]    @relation("ResultSnapshotPublishedBy")
  createdLessons           Lesson[]            @relation("LessonCreatedBy")
  publishedLessons         Lesson[]            @relation("LessonPublishedBy")
  createdAssignments       Assignment[]        @relation("AssignmentCreatedBy")
  submissions              Submission[]        @relation("SubmissionStudentUser")
  gradedSubmissions        Submission[]        @relation("SubmissionGradedBy")
  createdAssessments       Assessment[]        @relation("AssessmentCreatedBy")
  updatedAssessments       Assessment[]        @relation("AssessmentUpdatedBy")
  assessmentAttempts       AssessmentAttempt[] @relation("AssessmentAttemptStudentUser")
  manuallyGradedAssessmentAttempts AssessmentAttempt[] @relation("AssessmentAttemptManuallyGradedBy")
  uploadedAssets           FileAsset[]         @relation("FileAssetUploadedBy")
  reportedConductIncidents ConductIncident[]   @relation("ConductIncidentReportedBy")
  resolvedConductIncidents ConductIncident[]   @relation("ConductIncidentResolvedBy")
  createdConductActions    ConductAction[]     @relation("ConductActionCreatedBy")
  authoredConductFeedbacks ConductFeedback[]   @relation("ConductFeedbackAuthoredBy")
  createdConductGrades     ConductGrade[]      @relation("ConductGradeCreatedBy")
  updatedConductGrades     ConductGrade[]      @relation("ConductGradeUpdatedBy")
  govAuditorScopes         GovAuditorScope[]   @relation("GovAuditorUser")
  assignedGovAuditorScopes GovAuditorScope[]   @relation("GovAuditorScopeAssignedBy")
  payments                 Payment[]
  programEnrollments       ProgramEnrollment[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles UserRole[]
  invites   Invite[]

  @@unique([tenantId, name])
  @@index([tenantId, isSystem])
}

model UserRole {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
}

model Invite {
  id               String       @id @default(uuid())
  tenantId         String
  email            String
  roleId           String
  tokenHash        String       @unique
  status           InviteStatus @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role           Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedByUser  User   @relation("InviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedByUser User?  @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email, roleId, status])
  @@index([tenantId, email, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, roleId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  terms  Term[]
  enrollments StudentEnrollment[]
  attendanceSessions AttendanceSession[]
  courses Course[]
  exams   Exam[]
  resultSnapshots ResultSnapshot[]
  conductGrades   ConductGrade[]
  timetableSlots TimetableSlot[]

  @@unique([tenantId, name])
  @@index([tenantId, isCurrent, isActive])
}

model Term {
  id             String   @id @default(uuid())
  tenantId       String
  academicYearId String
  name           String
  sequence       Int
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  exams        Exam[]
  resultSnapshots ResultSnapshot[]
  conductGrades   ConductGrade[]
  timetableSlots TimetableSlot[]

  @@unique([tenantId, academicYearId, name])
  @@unique([tenantId, academicYearId, sequence])
  @@index([tenantId, academicYearId])
  @@index([tenantId, startDate, endDate])
}

model GradeLevel {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  rank      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classRooms ClassRoom[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, rank, isActive])
}

model ClassRoom {
  id           String   @id @default(uuid())
  tenantId     String
  gradeLevelId String
  code         String
  name         String
  capacity     Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  enrollments StudentEnrollment[]
  attendanceSessions AttendanceSession[]
  attendanceRecords AttendanceRecord[]
  courses Course[]
  exams   Exam[]
  resultSnapshots ResultSnapshot[]
  conductIncidents ConductIncident[]
  conductGrades    ConductGrade[]
  timetableSlots TimetableSlot[]

  @@unique([tenantId, code])
  @@unique([tenantId, gradeLevelId, name])
  @@index([tenantId, gradeLevelId, isActive])
}

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  isCore      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  courses Course[]
  exams   Exam[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, isCore, isActive])
}

model Student {
  id          String        @id @default(uuid())
  tenantId    String
  userId      String?       @unique
  studentCode String
  firstName   String
  lastName    String
  gender      StudentGender?
  dateOfBirth DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user        User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  enrollments StudentEnrollment[]
  parentLinks ParentStudent[]
  attendanceRecords AttendanceRecord[]
  submissions Submission[]
  assessmentAttempts AssessmentAttempt[]
  examMarks      ExamMark[]
  resultSnapshots ResultSnapshot[]
  conductIncidents ConductIncident[]
  conductGrades    ConductGrade[]

  @@unique([tenantId, studentCode])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, isActive, createdAt])
  @@index([tenantId, deletedAt])
}

model ConductIncident {
  id                String                @id @default(uuid())
  tenantId          String
  studentId         String
  classRoomId       String?
  reportedByUserId  String
  occurredAt        DateTime
  category          String
  title             String
  description       String
  severity          ConductSeverity       @default(MODERATE)
  status            ConductIncidentStatus @default(OPEN)
  location          String?
  reporterNotes     String?
  resolutionSummary String?
  resolvedAt        DateTime?
  resolvedByUserId  String?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student        Student         @relation(fields: [studentId], references: [id], onDelete: Restrict)
  classRoom      ClassRoom?      @relation(fields: [classRoomId], references: [id], onDelete: SetNull)
  reportedByUser User            @relation("ConductIncidentReportedBy", fields: [reportedByUserId], references: [id], onDelete: Restrict)
  resolvedByUser User?           @relation("ConductIncidentResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  actions        ConductAction[]
  feedback       ConductFeedback[]

  @@index([tenantId, studentId, occurredAt])
  @@index([tenantId, classRoomId, occurredAt])
  @@index([tenantId, status, severity, occurredAt])
}

model ConductAction {
  id              String            @id @default(uuid())
  tenantId        String
  incidentId      String
  createdByUserId String
  type            ConductActionType
  title           String
  description     String?
  actionDate      DateTime
  dueDate         DateTime?
  completedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  incident      ConductIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  createdByUser User            @relation("ConductActionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, incidentId, actionDate])
  @@index([tenantId, type, actionDate])
}

model ConductFeedback {
  id          String                    @id @default(uuid())
  tenantId    String
  incidentId  String
  authorUserId String
  authorType  ConductFeedbackAuthorType
  body        String
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  incident   ConductIncident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorUser User            @relation("ConductFeedbackAuthoredBy", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, incidentId, createdAt])
  @@index([authorUserId, createdAt])
}

model ConductGrade {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  termId          String
  classRoomId     String
  studentId       String
  grade           String
  remark          String?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term           Term       @relation(fields: [termId], references: [id], onDelete: Restrict)
  classRoom      ClassRoom  @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  student        Student    @relation(fields: [studentId], references: [id], onDelete: Restrict)
  createdByUser  User       @relation("ConductGradeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser  User       @relation("ConductGradeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, termId, classRoomId, studentId])
  @@index([tenantId, termId, classRoomId])
}

model GovAuditorScope {
  id               String        @id @default(uuid())
  auditorUserId    String
  assignedByUserId String?
  scopeLevel       GovScopeLevel
  country          String        @default("Rwanda")
  province         String?
  district         String?
  sector           String?
  notes            String?
  startsAt         DateTime?
  endsAt           DateTime?
  isActive         Boolean       @default(true)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  auditorUser    User  @relation("GovAuditorUser", fields: [auditorUserId], references: [id], onDelete: Cascade)
  assignedByUser User? @relation("GovAuditorScopeAssignedBy", fields: [assignedByUserId], references: [id], onDelete: SetNull)

  @@index([auditorUserId, isActive, scopeLevel])
  @@index([scopeLevel, country, province, district, sector])
}

model StudentEnrollment {
  id             String   @id @default(uuid())
  tenantId       String
  studentId      String
  academicYearId String
  classRoomId    String
  enrolledAt     DateTime @default(now())
  endedAt        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classRoom    ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Restrict)

  @@unique([tenantId, studentId, academicYearId])
  @@index([tenantId, classRoomId, academicYearId, isActive])
  @@index([tenantId, studentId, isActive])
  @@index([tenantId, academicYearId, isActive])
}

model Parent {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?  @unique
  parentCode String?
  firstName  String
  lastName   String
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  students ParentStudent[]

  @@unique([tenantId, parentCode])
  @@unique([tenantId, email])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, isActive, createdAt])
}

model ParentStudent {
  id           String             @id @default(uuid())
  tenantId     String
  parentId     String
  studentId    String
  relationship ParentRelationship @default(GUARDIAN)
  isPrimary    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, parentId, studentId])
  @@index([tenantId, studentId, relationship])
  @@index([tenantId, parentId, relationship])
}

model Course {
  id             String   @id @default(uuid())
  tenantId       String
  academicYearId String
  classRoomId    String
  subjectId      String?
  teacherUserId  String
  title          String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classRoom    ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  subject      Subject?     @relation(fields: [subjectId], references: [id], onDelete: SetNull)
  teacherUser  User         @relation("CourseTeacher", fields: [teacherUserId], references: [id], onDelete: Restrict)
  lessons      Lesson[]
  assignments  Assignment[]
  assessments  Assessment[]
  programs     Program[]
  timetableSlots TimetableSlot[]

  @@unique([tenantId, academicYearId, classRoomId, teacherUserId, title])
  @@index([tenantId, classRoomId, academicYearId, isActive])
  @@index([tenantId, teacherUserId, isActive])
}

model Lesson {
  id                String            @id @default(uuid())
  tenantId          String
  courseId          String
  title             String
  summary           String?
  contentType       LessonContentType
  body              String?
  externalUrl       String?
  fileAssetId       String?
  sequence          Int
  isPublished       Boolean           @default(false)
  publishedAt       DateTime?
  createdByUserId   String
  publishedByUserId String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  course          Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fileAsset       FileAsset? @relation("LessonFileAsset", fields: [fileAssetId], references: [id], onDelete: SetNull)
  createdByUser   User      @relation("LessonCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  publishedByUser User?     @relation("LessonPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)
  assignments     Assignment[]
  assessments     Assessment[]

  @@unique([tenantId, courseId, sequence])
  @@index([tenantId, courseId, isPublished, sequence])
  @@index([tenantId, publishedAt])
}

model Assignment {
  id              String   @id @default(uuid())
  tenantId        String
  courseId        String
  lessonId        String?
  title           String
  instructions    String
  attachmentAssetId String?
  dueAt           DateTime?
  maxPoints       Int      @default(100)
  isPublished     Boolean  @default(true)
  createdByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  course          Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson          Lesson?    @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  attachmentAsset FileAsset? @relation("AssignmentAttachmentAsset", fields: [attachmentAssetId], references: [id], onDelete: SetNull)
  createdByUser   User       @relation("AssignmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  submissions     Submission[]

  @@index([tenantId, courseId, dueAt])
  @@index([tenantId, lessonId])
  @@index([tenantId, isPublished, dueAt])
}

model Assessment {
  id              String   @id @default(uuid())
  tenantId        String
  courseId        String
  lessonId        String?
  type            AssessmentType @default(GENERAL)
  title           String
  instructions    String?
  dueAt           DateTime?
  timeLimitMinutes Int?
  maxAttempts     Int      @default(1)
  isPublished     Boolean  @default(false)
  publishedAt     DateTime?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  course        Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson        Lesson?   @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  createdByUser User      @relation("AssessmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser User      @relation("AssessmentUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  questions     AssessmentQuestion[]
  attempts      AssessmentAttempt[]

  @@index([tenantId, courseId, isPublished, dueAt])
  @@index([tenantId, lessonId])
  @@index([tenantId, createdByUserId, isPublished])
}

model AssessmentQuestion {
  id            String                 @id @default(uuid())
  tenantId      String
  assessmentId  String
  prompt        String
  explanation   String?
  type          AssessmentQuestionType @default(MCQ_SINGLE)
  sequence      Int
  points        Int                    @default(1)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assessment  Assessment       @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  options     AssessmentOption[]
  answers     AssessmentAnswer[]

  @@unique([tenantId, assessmentId, sequence])
  @@index([tenantId, assessmentId, sequence])
}

model AssessmentOption {
  id          String   @id @default(uuid())
  tenantId    String
  questionId  String
  label       String
  sequence    Int
  isCorrect   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  question     AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers      AssessmentAnswer[]

  @@unique([tenantId, questionId, sequence])
  @@index([tenantId, questionId, sequence])
}

model AssessmentAttempt {
  id              String                  @id @default(uuid())
  tenantId        String
  assessmentId    String
  studentId       String
  studentUserId   String
  attemptNumber   Int
  status          AssessmentAttemptStatus @default(IN_PROGRESS)
  startedAt       DateTime                @default(now())
  submittedAt     DateTime?
  autoScore       Int?
  maxScore        Int?
  manualScore     Int?
  manualFeedback  String?
  manuallyGradedAt DateTime?
  manuallyGradedByUserId String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assessment   Assessment        @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  studentUser  User              @relation("AssessmentAttemptStudentUser", fields: [studentUserId], references: [id], onDelete: Restrict)
  manuallyGradedByUser User?     @relation("AssessmentAttemptManuallyGradedBy", fields: [manuallyGradedByUserId], references: [id], onDelete: SetNull)
  answers      AssessmentAnswer[]

  @@unique([tenantId, assessmentId, studentId, attemptNumber])
  @@index([tenantId, assessmentId, status, startedAt])
  @@index([tenantId, studentId, status, updatedAt])
  @@index([tenantId, manuallyGradedByUserId, updatedAt])
}

model AssessmentAnswer {
  id               String   @id @default(uuid())
  tenantId         String
  attemptId        String
  questionId       String
  selectedOptionId String?
  textResponse     String?
  isCorrect        Boolean?
  pointsAwarded    Int?
  manualPointsAwarded Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  attempt        AssessmentAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       AssessmentQuestion @relation(fields: [questionId], references: [id], onDelete: Restrict)
  selectedOption AssessmentOption?  @relation(fields: [selectedOptionId], references: [id], onDelete: SetNull)

  @@unique([tenantId, attemptId, questionId])
  @@index([tenantId, questionId])
  @@index([tenantId, selectedOptionId])
}

model Submission {
  id              String           @id @default(uuid())
  tenantId        String
  assignmentId    String
  studentId       String
  studentUserId   String
  textAnswer      String?
  linkUrl         String?
  fileAssetId     String?
  status          SubmissionStatus @default(SUBMITTED)
  submittedAt     DateTime         @default(now())
  gradedAt        DateTime?
  gradePoints     Int?
  feedback        String?
  gradedByUserId  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignment     Assignment  @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Restrict)
  studentUser    User        @relation("SubmissionStudentUser", fields: [studentUserId], references: [id], onDelete: Restrict)
  fileAsset      FileAsset?  @relation("SubmissionFileAsset", fields: [fileAssetId], references: [id], onDelete: SetNull)
  gradedByUser   User?       @relation("SubmissionGradedBy", fields: [gradedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, assignmentId, studentId])
  @@index([tenantId, assignmentId, status, submittedAt])
  @@index([tenantId, studentId, submittedAt])
}

model FileAsset {
  id             String                @id @default(uuid())
  tenantId       String
  uploadedByUserId String
  publicId       String
  secureUrl      String
  originalName   String
  bytes          Int?
  format         String?
  mimeType       String?
  resourceType   FileAssetResourceType
  createdAt      DateTime              @default(now())

  tenant            Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  uploadedByUser    User          @relation("FileAssetUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: Restrict)
  lessonFiles       Lesson[]      @relation("LessonFileAsset")
  assignmentFiles   Assignment[]  @relation("AssignmentAttachmentAsset")
  submissionFiles   Submission[]  @relation("SubmissionFileAsset")

  @@unique([tenantId, publicId])
  @@index([tenantId, uploadedByUserId, createdAt])
  @@index([tenantId, resourceType, createdAt])
}

model GradingScheme {
  id              String   @id @default(uuid())
  tenantId        String
  name            String
  version         Int      @default(1)
  description     String?
  rules           Json
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  createdByUser  User     @relation("GradingSchemeCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser  User     @relation("GradingSchemeUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  exams          Exam[]
  resultSnapshots ResultSnapshot[]

  @@unique([tenantId, name, version])
  @@index([tenantId, isDefault, isActive])
  @@index([tenantId, createdAt])
}

model Exam {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  termId          String
  classRoomId     String
  subjectId       String
  gradingSchemeId String
  teacherUserId   String
  examType        ExamType @default(EXAM)
  name            String
  description     String?
  totalMarks      Int      @default(100)
  weight          Int      @default(100)
  examDate        DateTime?
  isActive        Boolean  @default(true)
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear   AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term           Term          @relation(fields: [termId], references: [id], onDelete: Restrict)
  classRoom      ClassRoom     @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  subject        Subject       @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  gradingScheme  GradingScheme @relation(fields: [gradingSchemeId], references: [id], onDelete: Restrict)
  teacherUser    User          @relation("ExamTeacher", fields: [teacherUserId], references: [id], onDelete: Restrict)
  createdByUser  User          @relation("ExamCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedByUser  User          @relation("ExamUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)
  marks          ExamMark[]

  @@unique([tenantId, termId, classRoomId, subjectId, name])
  @@index([tenantId, termId, classRoomId, subjectId])
  @@index([tenantId, teacherUserId, createdAt])
  @@index([tenantId, gradingSchemeId])
}

model ExamMark {
  id              String   @id @default(uuid())
  tenantId        String
  examId          String
  studentId       String
  marksObtained   Int
  enteredByUserId String
  updatedByUserId String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Restrict)
  enteredByUser User     @relation("ExamMarkEnteredBy", fields: [enteredByUserId], references: [id], onDelete: Restrict)
  updatedByUser User     @relation("ExamMarkUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, examId, studentId])
  @@index([tenantId, examId, updatedAt])
  @@index([tenantId, studentId, updatedAt])
}

model ResultSnapshot {
  id                   String               @id @default(uuid())
  tenantId             String
  academicYearId       String
  termId               String
  classRoomId          String
  studentId            String
  gradingSchemeId      String
  gradingSchemeVersion Int
  status               ResultSnapshotStatus @default(LOCKED)
  payload              Json
  lockedAt             DateTime
  lockedByUserId       String
  publishedAt          DateTime?
  publishedByUserId    String?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  term            Term          @relation(fields: [termId], references: [id], onDelete: Restrict)
  classRoom       ClassRoom     @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  student         Student       @relation(fields: [studentId], references: [id], onDelete: Restrict)
  gradingScheme   GradingScheme @relation(fields: [gradingSchemeId], references: [id], onDelete: Restrict)
  lockedByUser    User          @relation("ResultSnapshotLockedBy", fields: [lockedByUserId], references: [id], onDelete: Restrict)
  publishedByUser User?         @relation("ResultSnapshotPublishedBy", fields: [publishedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, termId, classRoomId, studentId])
  @@index([tenantId, termId, classRoomId, status])
  @@index([tenantId, studentId, publishedAt])
}

model AttendanceSession {
  id              String                  @id @default(uuid())
  tenantId        String
  classRoomId     String
  academicYearId  String?
  sessionDate     DateTime
  status          AttendanceSessionStatus @default(OPEN)
  createdByUserId String
  editedByUserId  String
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classRoom    ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  academicYear AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  createdByUser User        @relation("AttendanceSessionCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  editedByUser  User        @relation("AttendanceSessionEditedBy", fields: [editedByUserId], references: [id], onDelete: Restrict)
  records      AttendanceRecord[]

  @@unique([tenantId, classRoomId, sessionDate])
  @@index([tenantId, sessionDate])
  @@index([tenantId, classRoomId, sessionDate])
}

model AttendanceRecord {
  id             String           @id @default(uuid())
  tenantId       String
  sessionId      String
  classRoomId    String
  studentId      String
  attendanceDate DateTime
  status         AttendanceStatus @default(PRESENT)
  remarks        String?
  markedByUserId String
  editedByUserId String
  markedAt       DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  session      AttendanceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  classRoom    ClassRoom         @relation(fields: [classRoomId], references: [id], onDelete: Restrict)
  student      Student           @relation(fields: [studentId], references: [id], onDelete: Restrict)
  markedByUser User              @relation("AttendanceRecordMarkedBy", fields: [markedByUserId], references: [id], onDelete: Restrict)
  editedByUser User              @relation("AttendanceRecordEditedBy", fields: [editedByUserId], references: [id], onDelete: Restrict)

  @@unique([tenantId, classRoomId, attendanceDate, studentId])
  @@index([tenantId, classRoomId, attendanceDate])
  @@index([tenantId, studentId, attendanceDate])
}

model RefreshToken {
  id                String   @id @default(uuid())
  tenantId          String
  userId            String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdByIp       String?
  userAgent         String?
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, revokedAt])
  @@index([tenantId, expiresAt])
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  tenantId    String
  actorUserId String?
  event       String
  entity      String?
  entityId    String?
  requestId   String?
  ipAddress   String?
  userAgent   String?
  payload     Json?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, event, createdAt])
  @@index([requestId])
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

model Program {
  id                     String   @id @default(uuid())
  tenantId               String
  title                  String
  description            String?
  thumbnail              String?
  price                  Float
  durationDays           Int      @default(30)
  isActive               Boolean  @default(true)
  listedInPublicCatalog  Boolean  @default(true)
  courseId               String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  course           Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  payments         Payment[]
  enrollments      ProgramEnrollment[]

  @@unique([tenantId, title])
  @@index([tenantId, isActive])
  @@index([tenantId, listedInPublicCatalog])
}

model Payment {
  id                 String          @id @default(uuid())
  tenantId           String
  buyerTenantId      String?
  userId             String
  programId          String
  amount             Float
  planId             String?
  durationDays       Int?
  currency           String          @default("RWF")
  status             PaymentStatus   @default(PENDING)
  channel            String?
  paypackRef         String?         @unique
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  tenant             Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  buyerTenant        Tenant?         @relation("PaymentBuyerTenant", fields: [buyerTenantId], references: [id], onDelete: SetNull)
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  program            Program         @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([tenantId, status])
  @@index([userId, status])
  @@index([buyerTenantId])
}

model ProgramEnrollment {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  programId String
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  isTrial   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
  @@index([tenantId, isActive])
}

enum AnnouncementAudience {
  ALL
  CLASS_ROOM
  GRADE_LEVEL
}

model TimetableSlot {
  id              String   @id @default(uuid())
  tenantId        String
  academicYearId  String
  termId          String
  classRoomId    String
  courseId        String
  dayOfWeek      Int      // 1=Mon .. 5=Fri
  periodNumber   Int
  startTime      String   // HH:mm
  endTime        String   // HH:mm
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  term         Term         @relation(fields: [termId], references: [id], onDelete: Cascade)
  classRoom    ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, termId, classRoomId, dayOfWeek, periodNumber])
  @@index([tenantId, academicYearId, termId, classRoomId])
  @@index([tenantId, academicYearId, classRoomId])
}

model Announcement {
  id                String              @id @default(uuid())
  tenantId          String
  title             String
  body              String
  authorUserId      String
  audience          AnnouncementAudience @default(ALL)
  targetClassRoomIds String[]           @default([]) // when audience=CLASS_ROOM
  targetGradeLevelIds String[]          @default([]) // when audience=GRADE_LEVEL
  publishedAt       DateTime?
  expiresAt         DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  author User   @relation("AnnouncementAuthor", fields: [authorUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, publishedAt])
  @@index([tenantId, audience])
}
model PasswordResetToken {
  id        String   @id @default(uuid())
  tenantId  String
  email     String
  otp       String
  expiresAt DateTime
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, email])
  @@index([tenantId, email, otp])
}
