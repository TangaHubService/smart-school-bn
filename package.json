{
  "name": "smart-school-bn",
  "version": "0.1.0",
  "private": true,
  "description": "Smart School Rwanda backend foundation (Node.js + Express + Prisma)",
  "main": "dist/src/server.js",
  "scripts": {
    "start": "node dist/src/server.js",
    "start:dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:status": "prisma migrate status",
    "prisma:migrate:resolve:rolled-back": "bash prisma/scripts/resolve-failed-migration-rolled-back.sh",
    "prisma:migrate:deploy:sh": "bash prisma/scripts/migrate-deploy.sh",
    "prisma:migrate:psql": "bash prisma/scripts/apply-migrations-psql.sh",
    "prisma:check-duplicates": "ts-node prisma/scripts/check-duplicates.ts",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:add-timetable-permissions": "ts-node prisma/scripts/add-timetable-permissions.ts",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:integration": "jest --config jest.integration.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "@types/pdfkit": "^0.17.5",
    "axios": "^1.13.6",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.28.2",
    "cloudinary": "^2.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "qrcode": "^1.5.4",
    "rwanda": "^3.0.0",
    "socket.io": "^4.8.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^7.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/socket.io": "^3.0.1",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "prisma": "^6.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
  }
}
