generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum StudentGender {
  MALE
  FEMALE
  OTHER
  UNDISCLOSED
}

enum ParentRelationship {
  MOTHER
  FATHER
  GUARDIAN
  OTHER
}

model Tenant {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  domain    String?  @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  school        School?
  users         User[]
  roles         Role[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  invites       Invite[]
  academicYears AcademicYear[]
  terms         Term[]
  gradeLevels   GradeLevel[]
  classRooms    ClassRoom[]
  subjects      Subject[]
  students      Student[]
  enrollments   StudentEnrollment[]
  parents       Parent[]
  parentLinks   ParentStudent[]

  @@index([isActive])
}

model School {
  id                 String    @id @default(uuid())
  tenantId           String    @unique
  displayName        String
  registrationNumber String?   @unique
  email              String?
  phone              String?
  addressLine1       String?
  addressLine2       String?
  city               String?
  district           String?
  country            String    @default("Rwanda")
  timezone           String    @default("Africa/Kigali")
  setupCompletedAt   DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([country])
}

model User {
  id           String     @id @default(uuid())
  tenantId     String
  email        String
  passwordHash String
  firstName    String
  lastName     String
  status       UserStatus @default(ACTIVE)
  lastLoginAt  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tenant          Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles       UserRole[]
  refreshTokens   RefreshToken[]
  auditLogs       AuditLog[]
  sentInvites     Invite[]       @relation("InviteSentBy")
  acceptedInvites Invite[]       @relation("InviteAcceptedBy")
  parentProfile   Parent?

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model Role {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  description String?
  permissions Json
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles UserRole[]
  invites   Invite[]

  @@unique([tenantId, name])
  @@index([tenantId, isSystem])
}

model UserRole {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  roleId       String
  assignedById String?
  assignedAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
  @@index([tenantId, userId])
  @@index([tenantId, roleId])
}

model Invite {
  id               String       @id @default(uuid())
  tenantId         String
  email            String
  roleId           String
  tokenHash        String       @unique
  status           InviteStatus @default(PENDING)
  invitedByUserId  String
  acceptedByUserId String?
  expiresAt        DateTime
  acceptedAt       DateTime?
  revokedAt        DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tenant         Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  role           Role   @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedByUser  User   @relation("InviteSentBy", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedByUser User?  @relation("InviteAcceptedBy", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@unique([tenantId, email, roleId, status])
  @@index([tenantId, email, status])
  @@index([tenantId, expiresAt])
  @@index([tenantId, roleId])
}

model AcademicYear {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  startDate DateTime
  endDate   DateTime
  isCurrent Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  terms  Term[]
  enrollments StudentEnrollment[]

  @@unique([tenantId, name])
  @@index([tenantId, isCurrent, isActive])
}

model Term {
  id             String   @id @default(uuid())
  tenantId       String
  academicYearId String
  name           String
  sequence       Int
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([tenantId, academicYearId, name])
  @@unique([tenantId, academicYearId, sequence])
  @@index([tenantId, academicYearId])
  @@index([tenantId, startDate, endDate])
}

model GradeLevel {
  id        String   @id @default(uuid())
  tenantId  String
  code      String
  name      String
  rank      Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  classRooms ClassRoom[]

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, rank, isActive])
}

model ClassRoom {
  id           String   @id @default(uuid())
  tenantId     String
  gradeLevelId String
  code         String
  name         String
  capacity     Int?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  gradeLevel GradeLevel @relation(fields: [gradeLevelId], references: [id], onDelete: Restrict)
  enrollments StudentEnrollment[]

  @@unique([tenantId, code])
  @@unique([tenantId, gradeLevelId, name])
  @@index([tenantId, gradeLevelId, isActive])
}

model Subject {
  id          String   @id @default(uuid())
  tenantId    String
  code        String
  name        String
  description String?
  isCore      Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, code])
  @@unique([tenantId, name])
  @@index([tenantId, isCore, isActive])
}

model Student {
  id          String        @id @default(uuid())
  tenantId    String
  studentCode String
  firstName   String
  lastName    String
  gender      StudentGender?
  dateOfBirth DateTime?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  enrollments StudentEnrollment[]
  parentLinks ParentStudent[]

  @@unique([tenantId, studentCode])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, isActive, createdAt])
  @@index([tenantId, deletedAt])
}

model StudentEnrollment {
  id             String   @id @default(uuid())
  tenantId       String
  studentId      String
  academicYearId String
  classRoomId    String
  enrolledAt     DateTime @default(now())
  endedAt        DateTime?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Restrict)
  classRoom    ClassRoom    @relation(fields: [classRoomId], references: [id], onDelete: Restrict)

  @@unique([tenantId, studentId, academicYearId])
  @@index([tenantId, classRoomId, academicYearId, isActive])
  @@index([tenantId, studentId, isActive])
  @@index([tenantId, academicYearId, isActive])
}

model Parent {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?  @unique
  parentCode String?
  firstName  String
  lastName   String
  email      String?
  phone      String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user     User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  students ParentStudent[]

  @@unique([tenantId, parentCode])
  @@unique([tenantId, email])
  @@index([tenantId, lastName, firstName])
  @@index([tenantId, isActive, createdAt])
}

model ParentStudent {
  id           String             @id @default(uuid())
  tenantId     String
  parentId     String
  studentId    String
  relationship ParentRelationship @default(GUARDIAN)
  isPrimary    Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  deletedAt    DateTime?

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parent  Parent  @relation(fields: [parentId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([tenantId, parentId, studentId])
  @@index([tenantId, studentId, relationship])
  @@index([tenantId, parentId, relationship])
}

model RefreshToken {
  id                String   @id @default(uuid())
  tenantId          String
  userId            String
  tokenHash         String   @unique
  expiresAt         DateTime
  revokedAt         DateTime?
  replacedByTokenId String?
  createdByIp       String?
  userAgent         String?
  createdAt         DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, revokedAt])
  @@index([tenantId, expiresAt])
}

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  tenantId    String
  actorUserId String?
  event       String
  entity      String?
  entityId    String?
  requestId   String?
  ipAddress   String?
  userAgent   String?
  payload     Json?
  createdAt   DateTime @default(now())

  tenant    Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorUser User?  @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([tenantId, event, createdAt])
  @@index([requestId])
}
