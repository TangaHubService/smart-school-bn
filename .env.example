NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smart_school
JWT_ACCESS_SECRET=replace-with-at-least-32-chars-access-secret
JWT_REFRESH_SECRET=replace-with-at-least-32-chars-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=info
APP_VERSION=0.1.0
COMMIT_SHA=local-dev
BUILD_TIME=2026-03-06T00:00:00.000Z
APP_WEB_URL=http://localhost:5173
EMAIL_FROM=no-reply@smartschool.rw
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER_PREFIX=smart-school
FEATURE_CONDUCT_ENABLED=true
FEATURE_GOV_AUDITING_ENABLED=true
FEATURE_ASSESSMENTS_ENABLED=true

# Paypack Integration
PAYPACK_CLIENT_ID=
PAYPACK_CLIENT_SECRET=
PAYPACK_BASE_URL=https://payments.paypack.rw/api
PAYPACK_WEBHOOK_SECRET=
PAYPACK_WEBHOOK_MODE=development
